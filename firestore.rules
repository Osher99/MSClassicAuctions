rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isNotBanned() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != "banned";
    }

    function isConversationParticipant(conversationId) {
      return isAuthenticated() &&
        request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    // --- LISTINGS ---
    match /listings/{listingId} {
      // Anyone can read active listings
      allow read: if true;

      // Authenticated, non-banned users can create listings
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;

      // Owner or admin can update/delete
      allow update: if (isOwner(resource.data.userId) && isNotBanned()) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // --- USERS ---
    match /users/{userId} {
      // Authenticated users can read any profile (needed for listings display)
      allow read: if isAuthenticated();

      // Users can only create their own profile
      allow create: if isOwner(userId);

      // Users can update their own profile (except role/status fields)
      // Admins can update any profile (for banning/suspending)
      allow update: if (isOwner(userId) && isNotBanned()
          && !("role" in request.resource.data.diff(resource.data).affectedKeys())
          && !("status" in request.resource.data.diff(resource.data).affectedKeys()))
        || isAdmin();

      allow delete: if isAdmin();
    }

    // --- CONVERSATIONS ---
    match /conversations/{conversationId} {
      allow read: if isConversationParticipant(conversationId) || isAdmin();

      allow create: if isAuthenticated() && isNotBanned()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2;

      // Users can only update chat metadata for conversations they belong to
      allow update: if (
          isConversationParticipant(conversationId)
          && isNotBanned()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["lastMessage", "lastMessageTime", "lastMessageSender", "unreadCount"])
        ) || isAdmin();

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId) || isAdmin();

        allow create: if isConversationParticipant(conversationId)
          && isNotBanned()
          && request.resource.data.sender == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;

        allow update, delete: if false;
      }
    }

    // --- REPORTS ---
    match /reports/{reportId} {
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 500;

      allow read, update, delete: if isAdmin();
    }
  }
}
